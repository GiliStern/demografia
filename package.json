{
  "name": "demografia",
  "description": "Demografia is a satirical Israeli-themed survival game built with React Three Fiber.",
  "homepage": "https://gilistern.github.io/demografia/",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:phaser": "npm run lint:phaser && vite --config vite.phaser.config.ts --open /index-phaser.html",
    "build": "tsc && vite build",
    "build:phaser": "npm run lint:phaser && npm run test:phaser && npm run test:e2e:phaser && tsc && vite build --config vite.phaser.config.ts",
    "lint": "eslint --report-unused-disable-directives",
    "lint:phaser": "eslint src-phaser --max-warnings 0 --report-unused-disable-directives",
    "preview": "vite preview",
    "preview:phaser": "vite preview --config vite.phaser.config.ts",
    "test": "vitest",
    "test:phaser": "vitest run src-phaser/core",
    "test:e2e:phaser": "playwright test --config playwright.phaser.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@linaria/core": "^7.0.0",
    "@linaria/react": "^7.0.1",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.16.8",
    "@react-three/rapier": "^1.4.0",
    "@wyw-in-js/vite": "^1.0.6",
    "lucide-react": "^0.562.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "phaser": "^3.90.0",
    "three": "^0.160.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.2",
    "@storybook/addon-controls": "^8.4.7",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-links": "^8.4.7",
    "@storybook/addon-onboarding": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-storybook": "^0.11.1",
    "globals": "^16.5.0",
    "storybook": "^8.4.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-checker": "^0.11.0",
    "vitest": "^1.5.0"
  }
}
